{
  "manifest_version": 3,
  "name": "Restore App Connector",
  "version": "1.0",
  "description": "Connecting the Restore Cognitive Load Application to browser.",
  "icons": {
    "16": "main_icon.png",
    "48": "main_icon.png",
    "128": "main_icon.png"
  },
  "permissions": ["tabs"],
  "host_permissions": ["http://localhost:9147/*"],
  "background": {
    "service_worker": "background.js"
  }
}
